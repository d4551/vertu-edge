{
  "name": "control-plane",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "test": "bun test",
    "build": "bun run build:all",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:windows-x64",
    "build:linux-x64": "bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile dist/vertu-cp-linux-x64 src/index.ts",
    "build:linux-arm64": "bun build --compile --minify-whitespace --minify-syntax --target bun-linux-arm64 --outfile dist/vertu-cp-linux-arm64 src/index.ts",
    "build:darwin-arm64": "bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-arm64 --outfile dist/vertu-cp-darwin-arm64 src/index.ts",
    "build:darwin-x64": "bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-x64 --outfile dist/vertu-cp-darwin-x64 src/index.ts",
    "build:windows-x64": "bun build --compile --minify-whitespace --minify-syntax --target bun-windows-x64 --outfile dist/vertu-cp-windows-x64.exe src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.10",
    "drizzle-kit": "^0.31.9",
    "eslint": "10.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "dependencies": {
    "@elysiajs/html": "1.4.0",
    "@elysiajs/static": "1.4.7",
    "drizzle-orm": "^0.45.1",
    "elysia": "1.4.27",
    "jsonc-parser": "3.3.1",
    "yaml": "2.8.2"
  }
}
