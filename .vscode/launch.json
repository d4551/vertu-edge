{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Control Plane",
      "runtimeExecutable": "bun",
      "program": "${workspaceFolder}/control-plane/src/index.ts",
      "cwd": "${workspaceFolder}/control-plane",
      "env": {
        "CONTROL_PLANE_PORT": "3310"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Vertu Flow Kit: Validate",
      "runtimeExecutable": "bun",
      "program": "${workspaceFolder}/tooling/vertu-flow-kit/src/cli.ts",
      "args": ["validate", "${workspaceFolder}/contracts/fixtures/contact-flow.yaml"],
      "cwd": "${workspaceFolder}/tooling/vertu-flow-kit"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Vertu Flow Kit: Doctor",
      "runtimeExecutable": "bun",
      "program": "${workspaceFolder}/tooling/vertu-flow-kit/src/cli.ts",
      "args": ["doctor"],
      "cwd": "${workspaceFolder}/tooling/vertu-flow-kit"
    }
  ]
}
