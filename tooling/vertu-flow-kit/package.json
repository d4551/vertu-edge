    "doctor": "bun src/cli.ts doctor"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.10",
    "eslint": "10.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
