{
  "name": "@vertu/flow-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "vertu-flow": "src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
